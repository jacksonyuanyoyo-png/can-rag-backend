FASTGPT_BASE_URL=
FASTGPT_API_KEY=
FASTGPT_CHAT_PATH=/api/v1/chat/completions

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_VECTOR_STORE_NAME=default-rag-store
VLM_ENABLED=false
VLM_MODEL=gpt-4o-mini
VLM_TIMEOUT_SECONDS=60
VLM_MIN_IMAGE_BYTES=5120
VLM_MAX_IMAGE_BYTES=8000000
PDF_AUTO_ENHANCE_MIN_CHARS=100
DATABASE_URL=postgresql+psycopg://rag:rag_dev_change_me@127.0.0.1:5432/rag

LOCAL_UPLOAD_ROOT=app/storage/uploads
LOCAL_METADATA_PATH=app/storage/metadata/knowledge_bases.json
LOCAL_VECTOR_STORE_PATH=app/storage/vector_store
HTTP_TIMEOUT_SECONDS=60
WEB_FETCH_MAX_BYTES=5242880
WEB_FETCH_TIMEOUT_SECONDS=30
WEB_MIN_CONTENT_CHARS=200
WEB_LINK_DENSITY_MAX=0.35
WEB_ENABLE_BROWSER_FALLBACK=true
# 动态页兜底需可选安装: pip install playwright && playwright install chromium
RAG_BACKEND=postgres_pgvector
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_EMBEDDING_DIMENSIONS=256

# PDF 解析增强（OpenAI PDF/图片 OCR → Markdown），需 OPENAI_API_KEY
VLM_ENABLED=true
VLM_MODEL=gpt-4o-mini
PDF_VLM_MODEL=gpt-4o
PDF_AUTO_ENHANCE_MIN_CHARS=100
PDF_VLM_MIN_MARKDOWN_CHARS=80
PDF_RENDER_DPI=150

LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=fidelity-rag
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# 可选：仅当本机 5432 被占用时，供 docker compose 端口映射插值用
# POSTGRES_PORT=5433

# 应用连接本地 pgvector（账号密码与 docker/postgres/postgres.env 一致）
# DATABASE_URL=postgresql://rag:rag_dev_change_me@127.0.0.1:5432/rag

# 如果切换为 RAG_BACKEND=langchain_pgvector，需配置 OPENAI_API_KEY，
# 并通常将 RAG_EMBEDDING_DIMENSIONS 调整为 OpenAI embedding 模型维度（如 3072）。
